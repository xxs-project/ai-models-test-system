{
  "name": "@benchlocal/sdk",
  "version": "0.2.0",
  "description": "BenchLocal SDK for authoring Bench Packs on top of the BenchLocal runtime contract.",
  "author": "stevibe",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevibe/BenchLocal.git"
  },
  "homepage": "https://github.com/stevibe/BenchLocal",
  "bugs": {
    "url": "https://github.com/stevibe/BenchLocal/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "benchlocal",
    "benchpack",
    "llm",
    "benchmark",
    "sdk"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@benchlocal/core": "0.2.0"
  }
}
