class TestBenchmarkEndpoints:
    """基准测试端点测试"""
    
    def test_get_benchmarks_empty(self, client, db_session):
        """测试获取空基准测试列表"""
        response = client.get("/api/benchmarks")
        assert response.status_code == 200
        data = response.json()
        assert data["total"] == 0
    
    def test_create_benchmark(self, client, db_session):
        """测试创建基准测试"""
        benchmark_data = {
            "config": {
                "submitter": "admin",
                "modelName": "Qwen-7B",
                "serverName": "test-server",
                "chipName": "NVIDIA A100",
                "framework": "vLLM",
                "frameworkVersion": "0.4.0",
                "shardingConfig": "tp=1",
                "operatorAcceleration": "CUDA",
                "frameworkParams": "--dtype=half",
                "testDate": "2024-01-01",
                "notes": "测试基准"
            },
            "metrics": [
                {
                    "concurrency": 1,
                    "inputLength": 1024,
                    "outputLength": 512,
                    "ttft": 0.05,
                    "tpot": 0.01,
                    "tokensPerSecond": 100.0
                }
            ]
        }
        
        response = client.post("/api/benchmarks", json=benchmark_data)
        assert response.status_code == 200
        data = response.json()
        assert data["unique_id"].startswith("BM-")
        assert data["config"]["modelName"] == "Qwen-7B"

