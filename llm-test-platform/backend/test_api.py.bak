        update_data = {
            "interval_seconds": 120,
            "auto_refresh": True
        }
        
        with patch('main.scheduler') as mock_scheduler:
            mock_scheduler.remove_job = MagicMock()
            mock_scheduler.add_job = MagicMock()
            
            response = client.put("/api/settings", json=update_data)
            assert response.status_code == 200
            data = response.json()
            assert data["interval_seconds"] == 120
            assert data["auto_refresh"] == True

class TestDeviceMonitoringLogic:
    """设备监控逻辑测试"""
    
    def test_check_device_status_online(self):
        """测试在线设备状态检测"""
        with patch('paramiko.SSHClient'):
            from main import check_device_status_detailed
            from models import Device
            
            mock_device = Device(
                id=1,
                ip="192.168.1.100",
                port=22,
                username="root",
                password="password"
            )
            
            # 模拟SSH连接成功
            with patch('paramiko.SSHClient') as mock_ssh_client:
                mock_ssh = MagicMock()
                mock_ssh.exec_command.return_value = (
                    MagicMock(read=MagicMock(return_value=b'Ubuntu 22.04 LTS')),
                    MagicMock()
                )
                mock_ssh.exec_command.return_value = (
                    MagicMock(read=MagicMock(return_value=b'x86_64')),
                    MagicMock()
                )
                mock_ssh.exec_command.return_value = (
                    MagicMock(return_value=(b'NVIDIA A100, 40GB\nNVIDIA A100, 40GB', b'')),
                    MagicMock()
                )
                mock_ssh_client.return_value = mock_ssh
                
                result = check_device_status_detailed(mock_device)
                assert result.status == "Online"
    
    def test_check_device_status_offline(self):
        """测试离线设备状态检测"""
        from main import check_device_status_detailed
        from models import Device
        
        mock_device = Device(
            id=1,
            ip="192.168.1.100",
            port=22,
            username="root",
            password="wrongpassword"
        )
        
        # 模拟SSH连接失败
        with patch('paramiko.SSHClient') as mock_ssh_client:
            mock_ssh_client.return_value.connect.side_effect = Exception("Connection refused")
            
            result = check_device_status_detailed(mock_device)
            assert result.status == "Offline"
            assert result.error_message is not None

class TestReportEndpoints:
    """报告端点测试"""
    
    def test_get_reports_empty(self, client, db_session):
        """测试获取空报告列表"""
        response = client.get("/api/reports")
        assert response.status_code == 200
        data = response.json()
        assert isinstance(data, list)
    
    def test_create_report(self, client, db_session):
        """测试创建报告"""
        # 先创建基准测试
        benchmark_data = {
            "config": {
                "submitter": "admin",
                "modelName": "Qwen-7B",
                "serverName": "test-server",
                "chipName": "NVIDIA A100",
                "framework": "vLLM",
                "frameworkVersion": "0.4.0",
                "shardingConfig": "tp=1",
                "testDate": "2024-01-01"
            },
            "metrics": []
        }
        
        benchmark_response = client.post("/api/benchmarks", json=benchmark_data)
        benchmark_id = benchmark_response.json()["id"]
        
        # 创建第二个基准测试
        benchmark_data2 = benchmark_data.copy()
        benchmark_data2["config"]["modelName"] = "Qwen-14B"
        benchmark_response2 = client.post("/api/benchmarks", json=benchmark_data2)
        benchmark_id2 = benchmark_response2.json()["id"]
        
        # 创建报告
        report_data = {
            "benchmark_id1": benchmark_id,
            "benchmark_id2": benchmark_id2,
            "model_name1": "Qwen-7B",
            "model_name2": "Qwen-14B",
            "summary": "性能对比测试"
        }
        
        response = client.post("/api/reports", json=report_data)
        assert response.status_code == 200
        data = response.json()
        assert data["unique_id"].startswith("RP-")
        assert data["model_name1"] == "Qwen-7B"
        assert data["model_name2"] == "Qwen-14B"

if __name__ == "__main__":
    pytest.main([__file__, "-v"])
