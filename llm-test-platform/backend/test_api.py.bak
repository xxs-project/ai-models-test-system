import pytest
from fastapi.testclient import TestClient
from unittest.mock import patch, MagicMock
import sys
sys.path.insert(0, '/home/models-test-system_v1.0/llm-test-platform/backend')

sqlite_file_name = "test_database.db"
sqlite_url = f"sqlite:///{sqlite_file_name}"
connect_args = {"check_same_thread": False}
from sqlalchemy import create_engine
test_engine = create_engine(sqlite_url, connect_args=connect_args)

@pytest.fixture(scope="module")
def db_session():
    """创建测试数据库会话"""
    SQLModel.metadata.create_all(test_engine)
    with Session(test_engine) as session:
        yield session
        # 清理测试数据
        session.query(Report).delete()
        session.query(Benchmark).delete()
        session.query(Task).delete()
        session.query(Device).delete()
        session.query(Settings).delete()
        session.commit()

class TestHealthEndpoints:
    """健康检查端点测试"""
    
    def test_root_endpoint(self, client):
        """测试根端点返回正确信息"""
        response = client.get("/")
        assert response.status_code == 200
        data = response.json()
        assert "message" in data
        assert data["message"] == "大模型测试平台 API"
    
    def test_health_check(self, client):
        """测试健康检查端点"""
        response = client.get("/health")
        assert response.status_code == 200
        data = response.json()
        assert data["status"] == "healthy"
        assert "timestamp" in data

class TestDeviceEndpoints:
    """设备管理端点测试"""
    
    def test_get_devices_empty(self, client, db_session):
        """测试获取空设备列表"""
        response = client.get("/api/devices")
        assert response.status_code == 200
        data = response.json()
        assert "items" in data
        assert "total" in data
        assert "page" in data
        assert "size" in data
        assert data["total"] == 0
    
    def test_create_device(self, client, db_session):
        """测试创建设备"""
        device_data = {
            "ip": "192.168.1.100",
            "port": 22,
            "username": "root",
            "password": "password123"
        }
        
        with patch('main.refresh_single_device'):
            response = client.post("/api/devices", json=device_data)
            assert response.status_code == 200
            data = response.json()
            assert data["ip"] == "192.168.1.100"
            assert data["status"] == "Unknown"
            assert data["accelerator_count"] == 0
    
    def test_create_device_duplicate_ip(self, client, db_session):
        """测试创建重复IP设备"""
        device_data = {
            "ip": "192.168.1.100",
            "port": 22,
            "username": "root",
            "password": "password123"
        }
        
        with patch('main.refresh_single_device'):
            response = client.post("/api/devices", json=device_data)
            assert response.status_code == 400
            assert "已存在" in response.json()["detail"]
    
    def test_get_device(self, client, db_session):
        """测试获取单个设备"""
        with patch('main.refresh_single_device'):
            # 先创建设备
            device_data = {
                "ip": "192.168.1.101",
                "port": 22,
                "username": "admin",
                "password": "admin123"
            }
            create_response = client.post("/api/devices", json=device_data)
            device_id = create_response.json()["id"]
        
        response = client.get(f"/api/devices/{device_id}")
        assert response.status_code == 200
        data = response.json()
        assert data["ip"] == "192.168.1.101"
    
    def test_get_device_not_found(self, client):
        """测试获取不存在的设备"""
        response = client.get("/api/devices/99999")
        assert response.status_code == 404
        assert "不存在" in response.json()["detail"]
    
    def test_update_device(self, client, db_session):
        """测试更新设备"""
        with patch('main.refresh_single_device'):
            # 先创建设备
            device_data = {
                "ip": "192.168.1.102",
                "port": 22,
                "username": "root",
                "password": "password123"
            }
            create_response = client.post("/api/devices", json=device_data)
            device_id = create_response.json()["id"]
        
        update_data = {
            "remark": "测试服务器"
        }
        
        response = client.put(f"/api/devices/{device_id}", json=update_data)
        assert response.status_code == 200
        data = response.json()
        assert data["remark"] == "测试服务器"
    
    def test_delete_device(self, client, db_session):
        """测试删除设备"""
        with patch('main.refresh_single_device'):
            # 先创建设备
            device_data = {
                "ip": "192.168.1.103",
                "port": 22,
                "username": "root",
                "password": "password123"
            }
            create_response = client.post("/api/devices", json=device_data)
            device_id = create_response.json()["id"]
        
        response = client.delete(f"/api/devices/{device_id}")
        assert response.status_code == 200
        assert response.json()["ok"] == True
        
        # 验证设备已删除
        get_response = client.get(f"/api/devices/{device_id}")
        assert get_response.status_code == 404
    
    def test_refresh_device(self, client, db_session):
        """测试刷新设备状态"""
        with patch('main.refresh_single_device'):
            # 先创建设备
            device_data = {
                "ip": "192.168.1.104",
                "port": 22,
                "username": "root",
                "password": "password123"
            }
            create_response = client.post("/api/devices", json=device_data)
            device_id = create_response.json()["id"]
        
        with patch('main.check_device_status_detailed') as mock_check:
            mock_device = Device(
                id=device_id,
                ip="192.168.1.104",
                port=22,
                username="root",
                password="password",
                status="Online",
                accelerator_count=2,
                idle_count=2,
                busy_count=0,
                warning_count=0,
                os_info="Test OS",
                arch="x86_64",
                accelerator_type="NVIDIA"
            )
            mock_check.return_value = mock_device
            
            response = client.post(f"/api/devices/{device_id}/refresh")
            assert response.status_code == 200
            data = response.json()
            assert data["status"] == "Online"
    
    def test_filter_devices_by_status(self, client, db_session):
        """测试按状态筛选设备"""
        # 创建设备
        with patch('main.refresh_single_device'):
            client.post("/api/devices", json={
                "ip": "192.168.1.105",
                "port": 22,
                "username": "root",
                "password": "password"
            })
        
        response = client.get("/api/devices?status=Unknown")
        assert response.status_code == 200
        data = response.json()
        assert all(device["status"] == "Unknown" for device in data["items"])

class TestTaskEndpoints:
    """任务管理端点测试"""
    
