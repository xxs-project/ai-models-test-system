    def test_create_task(self, client, db_session):
        """测试创建任务"""
        task_data = {
            "task_name": "测试任务",
            "model_path": "/models/test-model",
            "inference_framework": "vLLM",
            "context_lengths": "1024,2048",
            "concurrencies": "1,8,16"
