{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": ".",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "incremental": false,
    "tsBuildInfoFile": "./tsconfig.benchlocal.tsbuildinfo"
  },
  "include": ["lib/**/*.ts", "benchlocal/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
