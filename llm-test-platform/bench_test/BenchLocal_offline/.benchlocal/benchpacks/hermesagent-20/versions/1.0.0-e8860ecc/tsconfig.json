{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["es2022", "dom"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "isolatedModules": false,
    "incremental": true,
    "types": ["node"]
  },
  "include": ["benchlocal/**/*.ts", "lib/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
