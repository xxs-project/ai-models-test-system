{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["es2022", "dom"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "isolatedModules": false,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["benchlocal/**/*.ts", "cli/**/*.ts", "lib/**/*.ts"],
  "exclude": ["node_modules", "dist", "dist-cli", ".next"]
}
