# Copy to .env.release.local and fill these values for a public macOS release.

# Required: Developer ID signing identity from the login keychain, without the prefix.
CSC_NAME="Your Name (TEAMID)"

# Preferred notarization flow: App Store Connect API key.
APPLE_API_KEY="/absolute/path/to/AuthKey_XXXXXXXXXX.p8"
APPLE_API_KEY_ID="XXXXXXXXXX"
APPLE_API_ISSUER="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Optional fallback Apple ID flow.
# APPLE_ID="you@example.com"
# APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"
# APPLE_TEAM_ID="TEAMID1234"
